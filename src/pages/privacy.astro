---
import Base from "../layouts/Base.astro";

const lastUpdated = "2026-06-01"; // update this whenever the policy changes
const lastUpdatedDisplay = "June 2026";
---

<Base
  title="Privacy Policy — Giftly Lists"
  description="Read the Giftly Lists privacy policy: what data we collect, how Google Sign-In, Firebase, RevenueCat, and AdMob are used, and how to request account deletion."
  canonicalPath="/privacy"
>
  <!-- Breadcrumb structured data -->
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Home",
          item: "https://giftlylists.com/",
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Privacy Policy",
          item: "https://giftlylists.com/privacy",
        },
      ],
    })}
  />

  <!-- Page Header -->
  <section class="relative pt-32 pb-12 sm:pt-40 sm:pb-16">
    <div class="absolute inset-0" aria-hidden="true">
      <div
        class="absolute top-0 left-1/4 w-[600px] h-[600px] bg-[#D90701]/[0.02] rounded-full blur-[120px]"
      >
      </div>
    </div>

    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Back Link -->

      <a
        href="/"
        class="inline-flex items-center gap-2 text-sm text-gray-500
      hover:text-[#D90701] transition-colors duration-200 mb-8 group"
      >
        <svg
          class="w-4 h-4 transition-transform duration-200 group-hover:-translate-x-1"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path d="M19 12H5M12 19l-7-7 7-7"></path>
        </svg>
        Back to home
      </a>

      <!-- Title -->
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-white mb-4">
        Privacy Policy
      </h1>
      <p class="text-sm text-gray-600">
        Last updated: <time datetime={lastUpdated}>{lastUpdatedDisplay}</time>
      </p>
    </div>
  </section>

  <!-- Content -->
  <section class="relative pb-24 sm:pb-32">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-invert prose-lg max-w-none">
        <!-- Introduction -->
        <p class="text-gray-400 leading-relaxed mb-8">
          Giftly Lists ("we", "our", or "us") is committed to protecting your
          privacy. This policy explains what information we collect, how we use
          it, and your choices.
        </p>

        <!-- Section 1 -->
        <div class="mb-12">
          <h2 class="text-xl font-semibold text-white mb-4">
            Information We Collect
          </h2>
          <ul class="space-y-3 list-none">
            <li class="flex gap-3 text-gray-400">
              <span class="text-[#D90701] mt-1 flex-shrink-0">•</span>
              <span
                ><strong class="text-gray-300">Account information:</strong> When
                you sign in with Google or Apple, we receive your name and email
                address.</span
              >
            </li>
            <li class="flex gap-3 text-gray-400">
              <span class="text-[#D90701] mt-1 flex-shrink-0">•</span>
              <span
                ><strong class="text-gray-300">List data:</strong> The gift lists,
                items, and invite codes you create are stored in our database.</span
              >
            </li>
            <li class="flex gap-3 text-gray-400">
              <span class="text-[#D90701] mt-1 flex-shrink-0">•</span>
              <span
                ><strong class="text-gray-300">Usage data:</strong> We collect basic
                analytics to understand how the app is used.</span
              >
            </li>
            <li class="flex gap-3 text-gray-400">
              <span class="text-[#D90701] mt-1 flex-shrink-0">•</span>
              <span
                ><strong class="text-gray-300">Advertising ID:</strong> With your
                permission, we use your device's advertising identifier to show relevant
                ads to free users.</span
              >
            </li>
          </ul>
        </div>

        <!-- Section 2 -->
        <div class="mb-12">
          <h2 class="text-xl font-semibold text-white mb-4">
            How We Use Your Information
          </h2>
          <ul class="space-y-3 list-none">
            <li class="flex gap-3 text-gray-400">
              <span class="text-[#D90701] mt-1 flex-shrink-0">•</span>
              <span>To provide and maintain the Giftly Lists service</span>
            </li>
            <li class="flex gap-3 text-gray-400">
              <span class="text-[#D90701] mt-1 flex-shrink-0">•</span>
              <span>To sync your lists across sessions</span>
            </li>
            <li class="flex gap-3 text-gray-400">
              <span class="text-[#D90701] mt-1 flex-shrink-0">•</span>
              <span>To process Pro subscription payments via Apple</span>
            </li>
            <li class="flex gap-3 text-gray-400">
              <span class="text-[#D90701] mt-1 flex-shrink-0">•</span>
              <span>To show ads to free users via Google AdMob</span>
            </li>
          </ul>
        </div>

        <!-- Section 3 -->
        <div class="mb-12">
          <h2 class="text-xl font-semibold text-white mb-4">
            Third-Party Services
          </h2>
          <p class="text-gray-400 mb-4">
            We use the following third-party services:
          </p>
          <ul class="space-y-3 list-none">
            <li class="flex gap-3 text-gray-400">
              <span class="text-[#D90701] mt-1 flex-shrink-0">•</span>
              <span
                ><strong class="text-gray-300">Firebase (Google):</strong> Authentication
                and database storage</span
              >
            </li>
            <li class="flex gap-3 text-gray-400">
              <span class="text-[#D90701] mt-1 flex-shrink-0">•</span>
              <span
                ><strong class="text-gray-300">RevenueCat:</strong> Subscription
                management</span
              >
            </li>
            <li class="flex gap-3 text-gray-400">
              <span class="text-[#D90701] mt-1 flex-shrink-0">•</span>
              <span
                ><strong class="text-gray-300">Google AdMob:</strong> Advertising
                for free users</span
              >
            </li>
          </ul>
        </div>

        <!-- Section 4 -->
        <div class="mb-12">
          <h2 class="text-xl font-semibold text-white mb-4">Data Retention</h2>
          <p class="text-gray-400 leading-relaxed">
            Your account and list data is retained as long as your account is
            active. You can delete your lists at any time within the app. To
            request full account deletion, email us at{" "}

            <a
              href="mailto:support@giftlylists.com"
              class="text-[#D90701]
            hover:text-[#BF0600] underline underline-offset-4 transition-colors
            duration-200"
            >
              support@giftlylists.com
            </a>.
          </p>
        </div>

        <!-- Section 5 -->
        <div class="mb-12">
          <h2 class="text-xl font-semibold text-white mb-4">
            Children's Privacy
          </h2>
          <p class="text-gray-400 leading-relaxed">
            Giftly Lists is not directed at children under 13. We do not
            knowingly collect personal information from children under 13.
          </p>
        </div>

        <!-- Section 6 -->
        <div class="mb-12">
          <h2 class="text-xl font-semibold text-white mb-4">Contact Us</h2>
          <p class="text-gray-400 leading-relaxed">
            If you have questions about this privacy policy, email us at{" "}

            <a
              href="mailto:support@giftlylists.com"
              class="text-[#D90701]
          hover:text-[#BF0600] underline underline-offset-4 transition-colors
          duration-200"
            >
              support@giftlylists.com
            </a>.
          </p>
        </div>
      </div>

      <!-- Footer Card -->
      <div
        class="mt-16 p-6 bg-white/[0.02] border border-white/[0.06] rounded-2xl"
      >
        <p class="text-sm text-gray-500 text-center">
          Have questions? We're here to help.{" "}

          <a
            href="/support"
            class="text-[#D90701] hover:text-[#BF0600]
      transition-colors duration-200"
          >
            Visit support
          </a>
        </p>
      </div>
    </div>
  </section>
</Base>
