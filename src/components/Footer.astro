---
// src/components/Footer.astro
---

<footer class="border-t border-white/[0.06]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <div
      class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-8"
    >
      <!-- Brand -->
      <div>
        <a
          href="/"
          class="flex items-center gap-2.5 group mb-3"
          aria-label="Giftly Lists home"
        >
          <span class="text-xl" aria-hidden="true">🎁</span>
          <span
            class="font-semibold text-white group-hover:text-[#D90701] transition-colors duration-200"
            >Giftly Lists</span
          >
        </a>
        <p class="text-sm text-gray-600">
          Share gift lists with the people you love.
        </p>
      </div>

      <!-- Links -->
      <div class="flex flex-wrap gap-6 sm:gap-8">
        <nav aria-label="Footer navigation">
          <ul class="flex flex-wrap gap-6 sm:gap-8 list-none">
            <li>
              <a
                href="/support"
                class="text-sm text-gray-500 hover:text-[#D90701] transition-colors duration-200"
              >
                Support
              </a>
            </li>
            <li>
              <a
                href="/privacy"
                class="text-sm text-gray-500 hover:text-[#D90701] transition-colors duration-200"
              >
                Privacy
              </a>
            </li>
            <li>
              <a
                href="https://apps.apple.com/us/app/giftly-lists-shared-lists/id6779746364"
                class="text-sm text-gray-500 hover:text-[#D90701] transition-colors duration-200"
              >
                Download
              </a>
            </li>
          </ul>
        </nav>
      </div>
    </div>

    <div
      class="mt-8 pt-8 border-t border-white/[0.04] flex flex-col sm:flex-row justify-between items-center gap-4"
    >
      <p class="text-xs text-gray-600">
        &copy; {new Date().getFullYear()} Giftly Lists. All rights reserved.
      </p>
      <p class="text-xs text-gray-700">Made with ❤️ for better gifting</p>
    </div>
  </div>
</footer>
