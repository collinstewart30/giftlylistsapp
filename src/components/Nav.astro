---
// src/components/Nav.astro
---

<header class="fixed top-0 left-0 right-0 z-50">
  <nav class="mx-4 mt-4 sm:mx-6 lg:mx-8" aria-label="Main navigation">
    <div
      class="max-w-7xl mx-auto bg-black/40 backdrop-blur-2xl border border-white/[0.06] rounded-2xl"
    >
      <div class="flex justify-between items-center h-16 px-4 sm:px-6">
        <!-- Logo -->
        <a
          href="/"
          class="flex items-center gap-2 sm:gap-3 group shrink-0"
          aria-label="Giftly Lists home"
        >
          <div
            class="w-9 h-9 bg-white/[0.04] border border-white/[0.08] rounded-xl flex items-center justify-center group-hover:border-[#D90701]/30 group-hover:scale-105 transition-all duration-300"
          >
            <span class="text-lg" aria-hidden="true">🎁</span>
          </div>
          <span
            class="font-semibold text-base sm:text-lg tracking-tight text-white"
          >
            Giftly Lists
          </span>
        </a>

        <!-- Desktop Navigation Links -->
        <ul class="hidden sm:flex items-center gap-1 list-none">
          <li>
            <a
              href="/support"
              class="px-4 py-2 text-sm text-gray-400 hover:text-white transition-colors duration-200 rounded-xl hover:bg-white/[0.04]"
            >
              Support
            </a>
          </li>
          <li>
            <a
              href="/privacy"
              class="px-4 py-2 text-sm text-gray-400 hover:text-white transition-colors duration-200 rounded-xl hover:bg-white/[0.04]"
            >
              Privacy
            </a>
          </li>
          <li class="ml-2">
            <a
              href="https://apps.apple.com/us/app/giftly-lists-shared-lists/id6779746364"
              class="inline-flex items-center gap-2 bg-[#D90701] hover:bg-[#BF0600] text-white px-5 py-2.5 rounded-xl font-medium text-sm transition-all duration-200 active:scale-[0.98]"
            >
              <svg
                class="w-4 h-4"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"
                ></path>
              </svg>
              Download
            </a>
          </li>
        </ul>

        <!-- Mobile: Download icon + Hamburger -->
        <div class="flex sm:hidden items-center gap-2">
          <a
            href="https://apps.apple.com/us/app/giftly-lists-shared-lists/id6779746364"
            class="inline-flex items-center gap-1.5 bg-[#D90701] hover:bg-[#BF0600] text-white px-3.5 py-2 rounded-xl font-medium text-xs transition-all duration-200 active:scale-[0.98]"
            aria-label="Download on the App Store"
          >
            <svg
              class="w-3.5 h-3.5"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"
              ></path>
            </svg>
            Get
          </a>

          <button
            id="nav-toggle"
            type="button"
            class="w-10 h-10 flex items-center justify-center rounded-xl border border-white/[0.08] text-gray-300 hover:text-white hover:bg-white/[0.04] transition-colors duration-200"
            aria-label="Toggle menu"
            aria-expanded="false"
            aria-controls="mobile-menu"
          >
            <svg
              id="icon-open"
              class="w-5 h-5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              aria-hidden="true"
            >
              <path d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
            <svg
              id="icon-close"
              class="w-5 h-5 hidden"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              aria-hidden="true"
            >
              <path d="M6 6l12 12M18 6L6 18"></path>
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile Dropdown Menu -->
      <div id="mobile-menu" class="hidden sm:hidden px-4 pb-4 pt-1">
        <ul
          class="flex flex-col gap-1 list-none border-t border-white/[0.06] pt-3"
        >
          <li>
            <a
              href="/support"
              class="block px-3 py-2.5 text-sm text-gray-400
            hover:text-white transition-colors duration-200 rounded-xl
            hover:bg-white/[0.04]"
            >
              Support
            </a>
          </li>
          <li>
            <a
              href="/privacy"
              class="block px-3 py-2.5 text-sm text-gray-400
          hover:text-white transition-colors duration-200 rounded-xl
          hover:bg-white/[0.04]"
            >
              Privacy
            </a>
          </li>
        </ul>
      </div>
    </div>

    <script>
      const toggle = document.getElementById("nav-toggle");
      const menu = document.getElementById("mobile-menu");
      const iconOpen = document.getElementById("icon-open");
      const iconClose = document.getElementById("icon-close");

      toggle?.addEventListener("click", () => {
        const isOpen = menu?.classList.contains("hidden") === false;

        menu?.classList.toggle("hidden");
        iconOpen?.classList.toggle("hidden");
        iconClose?.classList.toggle("hidden");
        toggle.setAttribute("aria-expanded", String(!isOpen));
      });

      // Close menu when a link inside it is clicked (helps on same-page navigation)
      menu?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
          menu.classList.add("hidden");
          iconOpen?.classList.remove("hidden");
          iconClose?.classList.add("hidden");
          toggle?.setAttribute("aria-expanded", "false");
        });
      });
    </script>
  </nav>
</header>
